# ── Core ──
SENTINEL_API_SECRET=change-me
SENTINEL_DUMMY=false
EVAL_COST_USDC=0.0001
# Comma-separated list. Leave empty to allow "*" (fine for the demo window).
# To lock down: set SENTINEL_ENV=prod and list the Vercel + demo URLs explicitly.
ALLOWED_ORIGINS=
# SENTINEL_ENV=prod

# ── Data plane (Railway injects these via reference variables) ──
# NOTE: SQLAlchemy needs the asyncpg driver. If Railway hands you
# `postgresql://...`, rewrite to `postgresql+asyncpg://...`.
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinel
REDIS_URL=redis://localhost:6379/0

# ── Arc L1 testnet ──
ARC_RPC_URL=
ARC_CHAIN_ID=0
REPUTATION_LEDGER_ADDRESS=
OPERATOR_POOL_ADDRESS=
ARC_USDC_ADDRESS=
SENTINEL_WALLET_PRIVATE_KEY=

# ── Ledger batching ──
LEDGER_BATCH_SIZE=100
LEDGER_BATCH_INTERVAL=60
POOL_DEBIT_INTERVAL=30

# ── Circle Nanopayments (optional, leave blank for demo) ──
CIRCLE_API_KEY=
CIRCLE_SELLER_ADDRESS=
CIRCLE_WALLET_SET_ID=
